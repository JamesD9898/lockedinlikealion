# Copy this to .env and fill in values

# MongoDB connection string
# Default: mongodb://localhost:27017/lockedinlikealion
MONGO_URI=mongodb://localhost:27017/lockedinlikealion

# Session secret - change this to something random in production
# Default: lockedinlikealion-dev-secret (fine for local use)
SESSION_SECRET=change-me-to-something-random

# Port (optional, defaults to 3000)
PORT=3000
