<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="container">
  <div class="breadcrumb">
    <a href="/courses">courses</a> / <span><%= course.title %></span>
  </div>

  <div class="page-header">
    <div>
      <h1><%= course.title %></h1>
      <% if (course.description) { %><p class="subtitle"><%= course.description %></p><% } %>
    </div>
    <div class="header-actions">
      <% if (course.units.length > 0) { %>
        <a href="/courses/<%= course.slug %>/notes" class="btn btn-secondary">notes</a>
        <button class="btn btn-secondary" onclick="showPracticeModal()">practice</button>
      <% } %>
      <a href="/courses/<%= course.slug %>/upload" class="btn btn-secondary">upload json</a>
    </div>
  </div>

  <!-- Practice modal -->
  <div id="practice-modal" class="modal hidden">
    <div class="modal-content fade-in">
      <h2>practice session</h2>
      <p style="font-size:0.8rem;color:var(--text-dim);margin-bottom:1rem;">pick units to pull questions from (or leave all checked for everything)</p>
      <div id="unit-checkboxes" style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.2rem;">
        <% course.units.forEach((unit, ui) => { %>
          <label style="display:flex;align-items:center;gap:0.6rem;font-size:0.82rem;cursor:pointer;">
            <input type="checkbox" name="unit" value="<%= ui %>" checked style="accent-color:var(--accent)">
            Unit <%= ui + 1 %> — <%= unit.title %>
          </label>
        <% }) %>
      </div>
      <div class="form-actions">
        <button type="button" class="btn btn-ghost" onclick="hidePracticeModal()">cancel</button>
        <button type="button" class="btn" onclick="startPractice()">start</button>
      </div>
    </div>
  </div>

  <% if (course.units.length === 0) { %>
    <div class="empty-state fade-in">
      <p>no units yet. <a href="/courses/<%= course.slug %>/upload">upload some content</a> to get started.</p>
    </div>
  <% } else { %>
    <div class="units-list">
      <% course.units.forEach((unit, ui) => { %>
        <div class="unit-card fade-in" style="animation-delay: <%= ui * 0.06 %>s">
          <div class="unit-header">
            <a href="/courses/<%= course.slug %>/unit/<%= ui %>">
              <span class="unit-number">Unit <%= ui + 1 %></span>
              <h2><%= unit.title %></h2>
            </a>
          </div>
          <div class="sets-list">
            <% unit.problemSets.forEach((ps, si) => { %>
              <% const prog = progressMap[ps._id.toString()]; %>
              <a href="/courses/<%= course.slug %>/unit/<%= ui %>/set/<%= si %>" class="set-item <%= prog && prog.completed ? 'set-done' : '' %>">
                <div class="set-info">
                  <span class="set-type-badge <%= ps.type %>"><%= ps.type === 'exam' ? 'exam' : 'set' %></span>
                  <span class="set-title"><%= ps.title %></span>
                  <% if (ps.timeLimit) { %>
                    <span class="set-time"><%= ps.timeLimit %> min</span>
                  <% } %>
                </div>
                <div class="set-status">
                  <% if (prog && prog.completed) { %>
                    <span class="check-mark">&#10003;</span>
                  <% } else if (prog) { %>
                    <span class="in-progress-dot"></span>
                  <% } %>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<script>
function showPracticeModal() {
  document.getElementById('practice-modal').classList.remove('hidden');
}
function hidePracticeModal() {
  document.getElementById('practice-modal').classList.add('hidden');
}
function startPractice() {
  const checked = Array.from(document.querySelectorAll('input[name="unit"]:checked')).map(el => el.value);
  if (checked.length === 0) return alert('select at least one unit');
  window.location.href = '/courses/<%= course.slug %>/practice?units=' + checked.join(',');
}
</script>

<%- include('partials/foot') %>
