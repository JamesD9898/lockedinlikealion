<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= problemSet.title %> — locked in like a lion</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
</head>
<body class="ps-body ps-immersive">

<header class="ps-hud">
  <a href="<%= typeof practiceMode !== 'undefined' && practiceMode
    ? '/courses/' + course.slug
    : '/courses/' + course.slug + '/unit/' + unitIndex %>" class="ps-hud-back" title="back">←</a>
  <div class="ps-hud-center">
    <span class="ps-hud-set"><span class="set-type-badge <%= problemSet.type %>"><%= problemSet.type === 'exam' ? 'exam' : 'set' %></span> <%= problemSet.title %></span>
    <span class="ps-hud-pos" id="ps-hud-pos">—</span>
  </div>
  <div class="ps-hud-right">
    <span id="timer-display" class="ps-hud-time">00:00</span>
    <button type="button" class="ps-hud-btn" id="btn-toggle-calc" onclick="PSApp.toggleCalc()">calc</button>
  </div>
</header>

<main class="ps-immersive-main" id="ps-immersive-main">

  <div class="ps-main-workspace" id="ps-main-workspace">
  <div class="ps-problem-strip" id="ps-problem-strip">
    <% problemSet.questions.forEach((q, qi) => { %>
    <div class="question-slide ps-q-slide" data-index="<%= qi %>" id="slide-<%= qi %>">
      <div class="question-card ps-q-card ps-q-card-compact">
        <div class="qcard-header">
          <span class="qcard-num">Question <%= q.number || (qi + 1) %></span>
          <% if (q.points) { %><span class="qcard-pts"><%= q.points %> pts</span><% } %>
        </div>
        <div class="qcard-stem katex-content"><%= q.text %></div>
        <% if (q.imageUrl) { %>
        <div class="qcard-image-wrap">
          <img src="<%= q.imageUrl %>" alt="Figure" class="qcard-image">
        </div>
        <% } %>
        <div class="qcard-answer-area">
          <% if (q.parts && q.parts.length > 0) { %>
            <% q.parts.forEach((part, pi) => { %>
            <div class="qpart" data-part-index="<%= pi %>">
              <div class="qpart-left">
                <span class="qpart-label"><%= part.label || '(' + String.fromCharCode(97 + pi) + ')' %></span>
              </div>
              <div class="qpart-right">
                <div class="qpart-text katex-content"><%= part.text %></div>
                <% if (part.points) { %><span class="qpart-pts"><%= part.points %> pts</span><% } %>
                <textarea class="answer-input" data-qid="<%= q._id %>" data-part="<%= pi %>" placeholder="answer…" rows="2"></textarea>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <textarea class="answer-input single-answer" data-qid="<%= q._id %>" placeholder="answer…" rows="2"></textarea>
          <% } %>
        </div>
        <div class="qcard-solution hidden" id="sol-<%= qi %>">
          <div class="solution-divider"></div>
          <div class="solution-label">Solution</div>
          <% if (q.parts && q.parts.length > 0) { %>
            <% q.parts.forEach((part, pi) => { %>
            <div class="solution-part">
              <span class="qpart-label solution-part-label"><%= part.label || '(' + String.fromCharCode(97 + pi) + ')' %></span>
              <div class="solution-text katex-content"><%= part.answer || '' %></div>
            </div>
            <% }) %>
          <% } else { %>
            <div class="solution-text katex-content"><%= q.answer || '' %></div>
          <% } %>
        </div>
      </div>
      <div class="q-action-bar ps-q-actions">
        <button class="btn-reveal" id="reveal-btn-<%= qi %>" onclick="PSApp.reveal(<%= qi %>)">reveal answer</button>
        <div class="grade-bar hidden" id="grade-bar-<%= qi %>">
          <span class="grade-label">grade</span>
          <button class="grade-btn" data-grade="correct" onclick="PSApp.grade(<%= qi %>, 'correct')">ok</button>
          <button class="grade-btn" data-grade="partial" onclick="PSApp.grade(<%= qi %>, 'partial')">partial</button>
          <button class="grade-btn" data-grade="incorrect" onclick="PSApp.grade(<%= qi %>, 'incorrect')">miss</button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="ps-canvas-wrap" id="ps-canvas-wrap">
    <div class="ps-canvas-shell" id="ps-canvas-shell">
      <canvas id="wb-main-canvas" aria-label="scratch paper"></canvas>
    </div>
    <div class="wbc-toolbar wb-toolbar-floating" id="wb-main-toolbar">
        <button class="wbc-tool active" data-tool="pen" title="pen">pen</button>
        <button class="wbc-tool" data-tool="highlighter" title="highlighter">hl</button>
        <button class="wbc-tool" data-tool="strike" title="strike">x</button>
        <button class="wbc-tool" data-tool="eraser" title="eraser">erase</button>
        <div class="wbc-divider"></div>
        <button class="wbc-swatch active" data-color="#1c1c1c" style="background:#1c1c1c" title="ink"></button>
        <button class="wbc-swatch" data-color="#c8a46e" style="background:#c8a46e"></button>
        <button class="wbc-swatch" data-color="#166534" style="background:#166534"></button>
        <button class="wbc-swatch" data-color="#b91c1c" style="background:#b91c1c"></button>
        <button class="wbc-swatch" data-color="#1d4ed8" style="background:#1d4ed8"></button>
        <div class="wbc-divider"></div>
        <button class="wbc-size" data-w="1">·</button>
        <button class="wbc-size active" data-w="2">–</button>
        <button class="wbc-size" data-w="4">━</button>
        <div class="wbc-divider"></div>
        <button class="wbc-action" data-wb-finger title="allow finger / mouse">touch</button>
        <button class="wbc-action" data-wb-undo title="undo">undo</button>
        <button class="wbc-action" data-wb-clear title="clear">clear</button>
    </div>
  </div>
  </div>

  <aside class="ps-calc-drawer" id="ps-calc-drawer" aria-hidden="true">
    <div class="ps-calc-resize-handle" id="ps-calc-resize-handle" title="drag to resize"></div>
    <div class="ps-calc-drawer-inner">
      <div class="ps-calc-head">
        <span>calculator</span>
        <button type="button" class="ps-calc-expand" onclick="PSApp.expandCalc()" title="fullscreen">expand</button>
        <button type="button" class="ps-calc-close" onclick="PSApp.toggleCalc()" title="close">×</button>
      </div>
      <div class="ps-calc-body" id="panel-calc">
        <div id="desmos-container" class="desmos-host"></div>
      </div>
    </div>
  </aside>
</main>

<div class="ps-end-screen hidden" id="end-screen">
  <div class="end-card">
    <div class="end-title">done.</div>
    <div class="end-time" id="end-time"></div>
    <div class="end-grades" id="end-grades"></div>
    <div class="end-breakdown" id="end-breakdown"></div>
    <div class="end-actions">
      <a href="/courses/<%= course.slug %><% if (typeof practiceMode === 'undefined' || !practiceMode) { %>/unit/<%= unitIndex %><% } %>" class="btn btn-ghost">back</a>
      <a href="/courses/<%= course.slug %>/notes" class="btn btn-ghost">notes</a>
      <button class="btn" onclick="PSApp.restart()">again</button>
    </div>
  </div>
</div>

<footer class="ps-footer ps-immersive-footer">
  <div class="ps-progress-dots" id="progress-dots">
    <% problemSet.questions.forEach((q, qi) => { %>
    <button class="pdot" data-index="<%= qi %>" id="pdot-<%= qi %>" onclick="PSApp.go(<%= qi %>)" title="Q<%= qi + 1 %>"></button>
    <% }) %>
  </div>
  <div class="ps-nav-center">
    <button type="button" class="ps-nav-btn" id="btn-prev" onclick="PSApp.prev()" title="previous part or question">←</button>
    <span class="ps-nav-pos" id="nav-pos">1 / <%= problemSet.questions.length %></span>
    <button type="button" class="ps-nav-btn" id="btn-next" onclick="PSApp.next()" title="next part or question">→</button>
  </div>
  <div class="ps-footer-right">
    <button class="btn btn-small btn-ghost" onclick="PSApp.finish()">finish</button>
  </div>
</footer>

<div class="tool-modal hidden" id="calc-modal">
  <div class="tool-modal-inner">
    <div class="tool-modal-header">
      <span>calculator</span>
      <button type="button" onclick="PSApp.collapseCalc()">close</button>
    </div>
    <div id="desmos-modal-container" class="desmos-modal-host"></div>
  </div>
</div>

<script>
window.__PS = {
  courseId:  '<%= course._id %>',
  psId:      '<%= problemSet._id %>',
  timeLimit: <%= problemSet.timeLimit || 'null' %>,
  totalQ:    <%= problemSet.questions.length %>,
  qIds:      [<%- problemSet.questions.map(q => JSON.stringify(String(q._id))).join(',') %>],
  qTexts:    [<%- problemSet.questions.map(q => JSON.stringify((q.text || '').substring(0, 120).replace(/\n/g, ' '))).join(',') %>],
  qNums:     [<%- problemSet.questions.map((q, i) => JSON.stringify(String(q.number || i + 1))).join(',') %>],
  partsLayout: <%- JSON.stringify(problemSet.questions.map(q => (q.parts && q.parts.length) ? q.parts.length : 0)) %>,
  existing:  <%- JSON.stringify(progress ? { timeSpent: progress.timeSpent || 0, answers: progress.answers || [] } : null) %>
};
</script>

<script src="https://www.desmos.com/api/v1.9/calculator.js?apiKey=dcb31709b452b1cf9dc26972add0fda6"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"
  onload="renderMathInElement(document.body, {
    delimiters: [
      {left:'$$',right:'$$',display:true},
      {left:'$',right:'$',display:false},
      {left:'\\\\(',right:'\\\\)',display:false},
      {left:'\\\\[',right:'\\\\]',display:true}
    ],
    throwOnError: false
  })"></script>
<script src="/js/whiteboard.js"></script>
<script src="/js/problem-set.js"></script>

</body>
</html>
