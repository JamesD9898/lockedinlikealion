<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= problemSet.title %> — locked in like a lion</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
</head>
<body class="ps-body">

<!-- ══════════════════════════════════════════════
     TOP BAR
══════════════════════════════════════════════ -->
<header class="ps-topbar">
  <a href="<%= typeof practiceMode !== 'undefined' && practiceMode
    ? '/courses/' + course.slug
    : '/courses/' + course.slug + '/unit/' + unitIndex %>" class="ps-back">
    ← <span class="ps-back-label"><%= course.title %><% if (typeof practiceMode === 'undefined' || !practiceMode) { %> · Unit <%= unitIndex + 1 %><% } %></span>
  </a>
  <div class="ps-topbar-title">
    <span class="set-type-badge <%= problemSet.type %>"><%= problemSet.type === 'exam' ? 'Exam' : 'Problem Set' %></span>
    <span><%= problemSet.title %></span>
  </div>
  <div class="ps-topbar-right">
    <div id="timer-display" class="ps-timer hidden">00:00</div>
    <button class="ps-timer-btn" onclick="PSApp.toggleTimer()" title="Toggle timer">⏱</button>
  </div>
</header>

<!-- ══════════════════════════════════════════════
     MAIN SPLIT
══════════════════════════════════════════════ -->
<main class="ps-main" id="ps-main">

  <!-- ── Left: question slides ── -->
  <div class="ps-question-col" id="ps-question-col">

    <% problemSet.questions.forEach((q, qi) => { %>
    <div class="question-slide" data-index="<%= qi %>" id="slide-<%= qi %>">

      <div class="question-card">
        <div class="qcard-header">
          <span class="qcard-num">Question <%= q.number || (qi + 1) %></span>
          <div style="display:flex;align-items:center;gap:0.6rem;">
            <% if (q.points) { %><span class="qcard-pts"><%= q.points %> pts</span><% } %>
            <button class="focus-launch-btn" onclick="PSApp.enterFocus(<%= qi %>)" title="Expand canvas to solve">
              ✏ solve
            </button>
          </div>
        </div>

        <div class="qcard-stem katex-content"><%= q.text %></div>

        <% if (q.imageUrl) { %>
        <div class="qcard-image-wrap">
          <img src="<%= q.imageUrl %>" alt="Figure" class="qcard-image">
        </div>
        <% } %>

        <div class="qcard-answer-area">
          <% if (q.parts && q.parts.length > 0) { %>
            <% q.parts.forEach((part, pi) => { %>
            <div class="qpart">
              <div class="qpart-left">
                <span class="qpart-label"><%= part.label || '(' + String.fromCharCode(97 + pi) + ')' %></span>
              </div>
              <div class="qpart-right">
                <div class="qpart-text katex-content"><%= part.text %></div>
                <% if (part.points) { %><span class="qpart-pts"><%= part.points %> pts</span><% } %>
                <textarea class="answer-input" data-qid="<%= q._id %>" data-part="<%= pi %>" placeholder="type notes here...  (draw on canvas →)" rows="2">
                </textarea>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <textarea class="answer-input single-answer" data-qid="<%= q._id %>" placeholder="type notes here...  (draw on canvas →)" rows="3">
            </textarea>
          <% } %>
        </div>

        <!-- Solution reveal -->
        <div class="qcard-solution hidden" id="sol-<%= qi %>">
          <div class="solution-divider"></div>
          <div class="solution-label">Solution</div>
          <% if (q.parts && q.parts.length > 0) { %>
            <% q.parts.forEach((part, pi) => { %>
            <div class="solution-part">
              <span class="qpart-label solution-part-label"><%= part.label || '(' + String.fromCharCode(97 + pi) + ')' %></span>
              <div class="solution-text katex-content"><%= part.answer || '' %></div>
            </div>
            <% }) %>
          <% } else { %>
            <div class="solution-text katex-content"><%= q.answer || '' %></div>
          <% } %>
        </div>
      </div>

      <!-- Action bar -->
      <div class="q-action-bar">
        <button class="btn-reveal" id="reveal-btn-<%= qi %>" onclick="PSApp.reveal(<%= qi %>)">
          reveal solution
        </button>
        <div class="grade-bar hidden" id="grade-bar-<%= qi %>">
          <span class="grade-label">how'd you do?</span>
          <button class="grade-btn" data-grade="correct"   onclick="PSApp.grade(<%= qi %>, 'correct')">nailed it</button>
          <button class="grade-btn" data-grade="partial"   onclick="PSApp.grade(<%= qi %>, 'partial')">partial</button>
          <button class="grade-btn" data-grade="incorrect" onclick="PSApp.grade(<%= qi %>, 'incorrect')">missed it</button>
        </div>
      </div>

    </div><!-- /question-slide -->
    <% }) %>

    <!-- End screen -->
    <div class="question-slide end-screen hidden" id="end-screen">
      <div class="end-card">
        <div class="end-title">done.</div>
        <div class="end-time" id="end-time"></div>
        <div class="end-grades" id="end-grades"></div>
        <div class="end-breakdown" id="end-breakdown"></div>
        <div class="end-actions">
          <a href="/courses/<%= course.slug %><% if (typeof practiceMode === 'undefined' || !practiceMode) { %>/unit/<%= unitIndex %><% } %>" class="btn btn-ghost">back</a>
          <a href="/courses/<%= course.slug %>/notes" class="btn btn-ghost">review notes</a>
          <button class="btn" onclick="PSApp.restart()">try again</button>
        </div>
      </div>
    </div>

  </div><!-- /ps-question-col -->

  <!-- ── Right: tools ── -->
  <div class="ps-tools-col" id="ps-tools-col">

    <button class="tools-toggle" id="tools-toggle" onclick="PSApp.toggleTools()" title="Toggle panel">
      <span id="tools-toggle-icon">›</span>
    </button>

    <!-- Tab bar -->
    <div class="tool-tabs">
      <button class="tool-tab active" data-panel="canvas" onclick="PSApp.switchTab('canvas')">canvas</button>
      <button class="tool-tab" data-panel="calc" onclick="PSApp.switchTab('calc')">calculator</button>
    </div>

    <!-- Canvas panel -->
    <div class="tool-panel" id="panel-canvas">
      <div class="wbc-toolbar" id="wbc-toolbar">
        <!-- Pen/Eraser -->
        <button class="wbc-tool active" data-tool="pen"    onclick="WB.setTool('pen');this.closest('.wbc-toolbar').querySelectorAll('.wbc-tool').forEach(b=>b.classList.remove('active'));this.classList.add('active')" title="Pen">✏</button>
        <button class="wbc-tool"        data-tool="eraser" onclick="WB.setTool('eraser');this.closest('.wbc-toolbar').querySelectorAll('.wbc-tool').forEach(b=>b.classList.remove('active'));this.classList.add('active')" title="Eraser">◻</button>

        <div class="wbc-divider"></div>

        <!-- Color swatches -->
        <button class="wbc-swatch active" data-color="#e8e8e8" style="background:#e8e8e8" onclick="WB.setColor(this.dataset.color)" title="White"></button>
        <button class="wbc-swatch" data-color="#c8a46e" style="background:#c8a46e" onclick="WB.setColor(this.dataset.color)" title="Gold"></button>
        <button class="wbc-swatch" data-color="#4ade80" style="background:#4ade80" onclick="WB.setColor(this.dataset.color)" title="Green"></button>
        <button class="wbc-swatch" data-color="#f87171" style="background:#f87171" onclick="WB.setColor(this.dataset.color)" title="Red"></button>
        <button class="wbc-swatch" data-color="#60a5fa" style="background:#60a5fa" onclick="WB.setColor(this.dataset.color)" title="Blue"></button>

        <div class="wbc-divider"></div>

        <!-- Sizes -->
        <button class="wbc-size"       data-w="1" onclick="WB.setWidth(1)" title="Fine">·</button>
        <button class="wbc-size active" data-w="2" onclick="WB.setWidth(2)" title="Medium">–</button>
        <button class="wbc-size"       data-w="4" onclick="WB.setWidth(4)" title="Thick">━</button>

        <div class="wbc-divider"></div>

        <!-- Undo / Clear -->
        <button class="wbc-action" onclick="WB.undo()" title="Undo">↩</button>
        <button class="wbc-action" onclick="if(confirm('clear canvas?')) WB.clear()" title="Clear">⌫</button>
      </div>
      <canvas id="wb-canvas"></canvas>
    </div>

    <!-- Calculator panel -->
    <div class="tool-panel hidden" id="panel-calc">
      <div id="desmos-container" style="flex:1;min-height:0;"></div>
    </div>

  </div><!-- /ps-tools-col -->
</main>

<!-- ══════════════════════════════════════════════
     BOTTOM NAV
══════════════════════════════════════════════ -->
<footer class="ps-footer">
  <div class="ps-progress-dots" id="progress-dots">
    <% problemSet.questions.forEach((q, qi) => { %>
    <button class="pdot" data-index="<%= qi %>" id="pdot-<%= qi %>" onclick="PSApp.go(<%= qi %>)" title="Q<%= qi + 1 %>"></button>
    <% }) %>
  </div>
  <div class="ps-nav-center">
    <button class="ps-nav-btn" id="btn-prev" onclick="PSApp.prev()">←</button>
    <span class="ps-nav-pos" id="nav-pos">1 / <%= problemSet.questions.length %></span>
    <button class="ps-nav-btn" id="btn-next" onclick="PSApp.next()">→</button>
  </div>
  <div class="ps-footer-right">
    <button class="btn btn-small btn-ghost" onclick="PSApp.finish()">finish</button>
  </div>
</footer>

<!-- ══════════════════════════════════════════════
     FOCUS MODE OVERLAY
     Full-screen canvas with question strip
══════════════════════════════════════════════ -->
<div id="focus-overlay" class="focus-overlay hidden">

  <!-- Collapsed question reference at top -->
  <div class="focus-strip" id="focus-strip">
    <div class="focus-strip-inner">
      <span class="focus-q-label" id="focus-q-label">Q1</span>
      <div class="focus-q-text" id="focus-q-text"></div>
    </div>
    <div class="focus-strip-actions">
      <button class="focus-reveal-btn" id="focus-reveal-btn" onclick="PSApp.revealFromFocus()">solution</button>
      <button class="focus-done-btn" onclick="PSApp.exitFocus()">done ↙</button>
    </div>
  </div>

  <!-- Full canvas -->
  <div class="focus-canvas-wrap">
    <canvas id="wb-focus-canvas"></canvas>
  </div>

  <!-- Floating toolbar -->
  <div class="focus-toolbar">
    <button class="wbc-tool active" data-tool="pen"    onclick="WB.setTool('pen');document.querySelectorAll('.focus-toolbar .wbc-tool').forEach(b=>b.classList.remove('active'));this.classList.add('active')">✏</button>
    <button class="wbc-tool"        data-tool="eraser" onclick="WB.setTool('eraser');document.querySelectorAll('.focus-toolbar .wbc-tool').forEach(b=>b.classList.remove('active'));this.classList.add('active')">◻</button>
    <div class="wbc-divider"></div>
    <button class="wbc-swatch active" data-color="#e8e8e8" style="background:#e8e8e8" onclick="WB.setColor(this.dataset.color)"></button>
    <button class="wbc-swatch" data-color="#c8a46e" style="background:#c8a46e" onclick="WB.setColor(this.dataset.color)"></button>
    <button class="wbc-swatch" data-color="#4ade80" style="background:#4ade80" onclick="WB.setColor(this.dataset.color)"></button>
    <button class="wbc-swatch" data-color="#f87171" style="background:#f87171" onclick="WB.setColor(this.dataset.color)"></button>
    <button class="wbc-swatch" data-color="#60a5fa" style="background:#60a5fa" onclick="WB.setColor(this.dataset.color)"></button>
    <div class="wbc-divider"></div>
    <button class="wbc-size"       data-w="1" onclick="WB.setWidth(1)">·</button>
    <button class="wbc-size active" data-w="2" onclick="WB.setWidth(2)">–</button>
    <button class="wbc-size"       data-w="4" onclick="WB.setWidth(4)">━</button>
    <div class="wbc-divider"></div>
    <button class="wbc-action" onclick="WB.undo()">↩</button>
    <button class="wbc-action" onclick="if(confirm('clear?')) WB.clear()">⌫</button>
    <div class="wbc-divider"></div>
    <button class="ps-nav-btn" onclick="PSApp.prevFromFocus()">←</button>
    <button class="ps-nav-btn" onclick="PSApp.nextFromFocus()">→</button>
  </div>

</div>

<!-- ══════════════════════════════════════════════
     DESMOS EXPAND MODAL
══════════════════════════════════════════════ -->
<div class="tool-modal hidden" id="calc-modal">
  <div class="tool-modal-inner">
    <div class="tool-modal-header">
      <span>calculator</span>
      <button onclick="PSApp.collapseCalc()">close ×</button>
    </div>
    <div id="desmos-modal-container" style="flex:1;min-height:0;"></div>
  </div>
</div>

<!-- ══════════════════════════════════════════════
     DATA + SCRIPTS
══════════════════════════════════════════════ -->
<script>
window.__PS = {
  courseId:  '<%= course._id %>',
  psId:      '<%= problemSet._id %>',
  timeLimit: <%= problemSet.timeLimit || 'null' %>,
  totalQ:    <%= problemSet.questions.length %>,
  qIds:      [<%- problemSet.questions.map(q => JSON.stringify(String(q._id))).join(',') %>],
  qTexts:    [<%- problemSet.questions.map(q => JSON.stringify((q.text || '').substring(0, 120).replace(/\n/g, ' '))).join(',') %>],
  qNums:     [<%- problemSet.questions.map((q, i) => JSON.stringify(String(q.number || i + 1))).join(',') %>],
  existing:  <%- JSON.stringify(progress ? { timeSpent: progress.timeSpent || 0, answers: progress.answers || [] } : null) %>
};
</script>

<script src="https://www.desmos.com/api/v1.9/calculator.js?apiKey=dcb31709b452b1cf9dc26972add0fda6"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"
  onload="renderMathInElement(document.body, {
    delimiters: [
      {left:'$$',right:'$$',display:true},
      {left:'$',right:'$',display:false},
      {left:'\\\\(',right:'\\\\)',display:false},
      {left:'\\\\[',right:'\\\\]',display:true}
    ],
    throwOnError: false
  })"></script>
<script src="/js/whiteboard.js"></script>
<script src="/js/problem-set.js"></script>

</body>
</html>
